<Window x:Class="PROG6221_POE_PART2_WPF.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Chat Bot"
        Height="680" Width="920"
        MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D"
        FontFamily="Consolas"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- ── Colour palette ─────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BackgroundBrush"      Color="#0D0D0D"/>
        <SolidColorBrush x:Key="PanelBrush"           Color="#111111"/>
        <SolidColorBrush x:Key="BorderBrush"          Color="#1A3A1A"/>
        <SolidColorBrush x:Key="AccentGreen"          Color="#00FF41"/>
        <SolidColorBrush x:Key="AccentCyan"           Color="#00E5FF"/>
        <SolidColorBrush x:Key="AccentYellow"         Color="#FFD600"/>
        <SolidColorBrush x:Key="AccentRed"            Color="#FF3D3D"/>
        <SolidColorBrush x:Key="TextMuted"            Color="#4A7A4A"/>
        <SolidColorBrush x:Key="InputBrush"           Color="#0A1A0A"/>
        <SolidColorBrush x:Key="ButtonHover"          Color="#003300"/>
        <SolidColorBrush x:Key="ScrollBarBrush"       Color="#1A3A1A"/>

        <!-- ── ScrollBar style: slim green ───────────────────────────── -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="#111111">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#1A5C1A" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ScrollViewer with slim scrollbar ─────────────────────── -->
        <Style x:Key="ChatScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ── Send button style ─────────────────────────────────────── -->
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background"   Value="#003300"/>
            <Setter Property="Foreground"   Value="#00FF41"/>
            <Setter Property="BorderBrush"  Value="#00FF41"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Padding"      Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005500"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00FF41"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#007700"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#111111"/>
                                <Setter Property="Foreground" Value="#2A4A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon button style (Clear / Mute) ─────────────────────── -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#4A7A4A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#00FF41"/>
                                <Setter TargetName="Bd" Property="Background" Value="#0A1A0A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Input TextBox style ───────────────────────────────────── -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="Background"        Value="#0A1A0A"/>
            <Setter Property="Foreground"        Value="#FFD600"/>
            <Setter Property="CaretBrush"        Value="#00FF41"/>
            <Setter Property="BorderBrush"       Value="#1A3A1A"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontFamily"        Value="Consolas"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Padding"           Value="10,8"/>
            <Setter Property="SelectionBrush"    Value="#003300"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00FF41"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  ROOT GRID                                                         -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- ASCII banner -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
            <RowDefinition Height="*"/>      <!-- Chat area -->
            <RowDefinition Height="Auto"/>   <!-- Input area -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Custom title bar ─────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#080808"
                BorderBrush="#1A3A1A"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Blinking dot indicator -->
                <Ellipse x:Name="StatusDot"
                         Grid.Column="0"
                         Width="8" Height="8"
                         Fill="#00FF41"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2"
                                                     Duration="0:0:1"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CYBER"
                               Foreground="#00FF41"
                               FontFamily="Consolas"
                               FontSize="13"
                               FontWeight="Bold"/>
                    <TextBlock Text="SECURITY"
                               Foreground="#00E5FF"
                               FontFamily="Consolas"
                               FontSize="13"
                               FontWeight="Bold"
                               Margin="4,0,0,0"/>
                    <TextBlock Text="AWARENESS BOT  //  v2.0"
                               Foreground="#2A5A2A"
                               FontFamily="Consolas"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <!-- Mute / Voice toggle button -->
                <Button x:Name="BtnMute"
                        Grid.Column="2"
                        Content="[ VOICE: ON ]"
                        Style="{StaticResource IconButton}"
                        Click="BtnMute_Click"
                        ToolTip="Toggle text-to-speech on/off"/>
            </Grid>
        </Border>

        <!-- ── Row 1: ASCII Banner ──────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#080808"
                BorderBrush="#1A3A1A"
                BorderThickness="0,0,0,1"
                Padding="16,10,16,10">
            <TextBlock x:Name="TxtBanner"
                       FontFamily="Consolas"
                       FontSize="9.5"
                       Foreground="#00FF41"
                       TextWrapping="NoWrap"
                       HorizontalAlignment="Center"
                       Text=""/>
        </Border>

        <!-- ── Row 2: Status bar ────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#0A0A0A"
                BorderBrush="#1A2A1A"
                BorderThickness="0,0,0,1"
                Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus"
                           Grid.Column="0"
                           Text="[ SYSTEM READY ]  ●  ENTER YOUR NAME TO BEGIN"
                           Foreground="#2A6A2A"
                           FontFamily="Consolas"
                           FontSize="10"/>
                <TextBlock x:Name="TxtTopicHistory"
                           Grid.Column="1"
                           Text=""
                           Foreground="#1A4A1A"
                           FontFamily="Consolas"
                           FontSize="10"/>
            </Grid>
        </Border>

        <!-- ── Row 3: Chat display ──────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#0D0D0D"
                BorderBrush="#1A2A1A"
                BorderThickness="1"
                Margin="8,6,8,0"
                CornerRadius="4">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent"
                          Padding="4,4,4,4">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScrollBar}"/>
                </ScrollViewer.Resources>
                <StackPanel x:Name="ChatPanel"
                            Margin="6,4"
                            Background="Transparent"/>
            </ScrollViewer>
        </Border>

        <!-- ── Row 4: Input area ────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="#080808"
                BorderBrush="#1A3A1A"
                BorderThickness="1"
                Margin="8,6,8,0"
                CornerRadius="4"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- User name prompt prefix -->
                <TextBlock x:Name="TxtPromptLabel"
                           Grid.Column="0"
                           Text="[ USER ] ▶ "
                           Foreground="#FFD600"
                           FontFamily="Consolas"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <!-- Message input box -->
                <TextBox x:Name="TxtInput"
                         Grid.Column="1"
                         Style="{StaticResource ChatInput}"
                         KeyDown="TxtInput_KeyDown"
                         TextChanged="TxtInput_TextChanged"
                         ToolTip="Type your message and press Enter or click SEND"/>

                <!-- Send button -->
                <Button x:Name="BtnSend"
                        Grid.Column="2"
                        Content="[ SEND ]"
                        Style="{StaticResource SendButton}"
                        Height="36"
                        Margin="8,0,0,0"
                        Click="BtnSend_Click"
                        IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- ── Row 5: Footer ────────────────────────────────────────── -->
        <Border Grid.Row="5"
                Background="#080808"
                Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="TYPE 'help' FOR AVAILABLE TOPICS  ●  'clear' TO RESET CHAT  ●  'exit' TO QUIT"
                           Foreground="#1A4A1A"
                           FontFamily="Consolas"
                           FontSize="9.5"
                           VerticalAlignment="Center"/>
                <Button x:Name="BtnClearChat"
                        Grid.Column="1"
                        Content="[ CLEAR CHAT ]"
                        Style="{StaticResource IconButton}"
                        Click="BtnClearChat_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
